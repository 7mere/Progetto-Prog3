<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>

<VBox spacing="10.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.unito.server.HelloController"
      prefHeight="600.0" prefWidth="800.0" style="-fx-padding: 20; -fx-background-color: #1e1e1e;">
    <Label text="Mail Server - Log Eventi" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    <ListView fx:id="logListView" VBox.vgrow="ALWAYS" style="-fx-font-family: 'Consolas'; -fx-font-size: 14px;"/>
</VBox>
