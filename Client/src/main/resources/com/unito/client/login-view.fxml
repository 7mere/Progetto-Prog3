<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="380.0" prefWidth="520.0"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.unito.client.LoginController"
           styleClass="root-pane">

    <padding>
        <Insets top="36.0" right="36.0" bottom="36.0" left="36.0"/>
    </padding>

    <VBox spacing="12.0" maxWidth="420.0" styleClass="card">
        <padding>
            <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
        </padding>

        <!-- Titolo -->
        <Label text="Login" styleClass="title-label">
            <font>
                <Font size="28.0"/>
            </font>
        </Label>

        <!-- Sottotitolo -->
        <Label text="Inserisci la tua email per continuare" styleClass="subtitle-label" wrapText="true">
            <font>
                <Font size="13.0"/>
            </font>
        </Label>

        <!-- Campo -->
        <VBox spacing="6.0">
            <Label text="Email" styleClass="field-label">
                <font>
                    <Font size="12.0"/>
                </font>
            </Label>

            <TextField fx:id="mailField"
                       promptText="nome@dominio.com"
                       prefHeight="42.0"
                       styleClass="email-field"/>
        </VBox>

        <!-- Bottone -->
        <Button text="Log In"
                onAction="#onLoginButtonClick"
                prefHeight="44.0"
                maxWidth="1.7976931348623157E308"
                styleClass="login-button"/>

        <!-- Messaggio -->
        <Label fx:id="result"
               prefHeight="56.0"
               minHeight="40.0"
               wrapText="true"
               styleClass="result-label">
            <font>
                <Font size="12.0"/>
            </font>
        </Label>
    </VBox>

</StackPane>
